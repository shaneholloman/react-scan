{
  "name": "root",
  "private": true,
  "scripts": {
    "build": "node scripts/workspace.mjs build",
    "postbuild": "node scripts/version-warning.mjs",
    "dev": "node scripts/workspace.mjs dev",
    "pack": "node scripts/workspace.mjs pack",
    "pack:bump": "pnpm --filter scan pack:bump",
