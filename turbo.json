{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "@react-scan/website#build": {
      "dependsOn": ["react-scan#build"]
    },
    "@react-scan/extension#build": {
      "dependsOn": ["react-scan#build"]
    },
    "@react-scan/kitchen-sink#dev": {
      "dependsOn": ["react-scan#build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "format": {},
    "check": {}
  }
}
